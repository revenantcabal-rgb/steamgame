# Supabase Configuration (optional - game works in offline/local mode without these)
# Create a project at https://supabase.com and get these values from Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Steam Configuration (set automatically by Electron/Steam)
# STEAM_APP_ID is read from steam_appid.txt, not env vars
